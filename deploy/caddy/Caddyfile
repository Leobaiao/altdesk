# ═══════════════════════════════════════════════════
# AltDesk — Caddyfile (Proxy Reverso com HTTPS Automático)
#
# O Caddy gerencia automaticamente os certificados
# Let's Encrypt para todos os domínios listados abaixo.
# Nenhuma configuração manual de SSL é necessária.
# ═══════════════════════════════════════════════════

{
	email admin@altdesk.com.br
}

# ─── PÁGINA "EM CONSTRUÇÃO" (Domínio Principal) ───
altdesk.com.br {
	@rootPath {
		path /
	}
	handle @rootPath {
		root * /var/www/static
		file_server
	}

	handle {
		redir https://app.altdesk.com.br{uri} permanent
	}
}

www.altdesk.com.br {
	redir https://altdesk.com.br{uri} permanent
}

# ─── FRONTEND (App Cliente) ───
app.altdesk.com.br {
	reverse_proxy frontend:80
}

# ─── FRONTEND (SuperAdmin) ───
admin.altdesk.com.br {
	reverse_proxy admin-frontend:80
}

# ─── BACKEND API (App API) ───
api.altdesk.com.br {
	reverse_proxy backend:3002

	# Permitir uploads maiores (ex: imagens de perfil)
	request_body {
		max_size 50MB
	}
}

# ─── ADMIN BACKEND API ───
api-admin.altdesk.com.br {
	reverse_proxy admin-backend:3002

	# Permitir uploads maiores
	request_body {
		max_size 50MB
	}
}

# ═══════════════════════════════════════════════════
# TUUVO — Projeto separado rodando na mesma VPS
# Os containers do Tuuvo expõem portas no host (4000 / 4002).
# O Caddy alcança o host via extra_hosts (host.docker.internal).
# ═══════════════════════════════════════════════════

# ─── TUUVO FRONTEND ───
tuuvo.app.br {
	reverse_proxy host.docker.internal:4000
}

www.tuuvo.app.br {
	redir https://tuuvo.app.br{uri} permanent
}

# ─── TUUVO BACKEND API ───
api.tuuvo.app.br {
	reverse_proxy host.docker.internal:4002

	request_body {
		max_size 50MB
	}
}
