# ============================================================
# AltDesk — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o .env no repositório!
# ============================================================

# Banco de Dados (SQL Server)
MSSQL_SA_PASSWORD=SuaSenhaForteAqui123!
DB_USER=sa
DB_PASS=SuaSenhaForteAqui123!
DB_NAME=AltDeskDev

# JWT (use uma string longa e aleatória, diferente da senha do banco)
JWT_SECRET=gere-uma-string-segura-com-pelo-menos-32-caracteres

# SMTP (para reset de senha)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AltDesk" <noreply@altdesk.com>

# Asaas Billing (opcional para MVP)
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=

# Frontend URLs (separar por vírgula se múltiplas)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
